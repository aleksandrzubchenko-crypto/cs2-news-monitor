.env
# seen.json is intentionally committed: the Actions run persists it back so the
# dedupe store survives across runs (otherwise every run re-posts the same items).
__pycache__/
*.pyc
# card renderer test output (runtime uses the temp dir, not the repo)
/card_test.png

# card template test artifacts
assets/templates/*/_preview*.png
assets/templates/*/_check*.png
